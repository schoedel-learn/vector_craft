{
  "hosting": {
    "public": "dist",
    "predeploy": [
      "npm run build"
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "database": "ai-studio-f4b239be-2a4d-4958-b64a-6548cbfb7948",
    "rules": "firestore.rules"
  }
}
