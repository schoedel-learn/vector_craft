{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role"
        }
      },
      "required": ["role"]
    },
    "SvgDocument": {
      "title": "SvgDocument",
      "description": "A generated SVG document",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user ID of the creator"
        },
        "prompt": {
          "type": "string",
          "description": "The prompt used to generate the SVG"
        },
        "content": {
          "type": "string",
          "description": "The raw SVG code"
        },
        "timestamp": {
          "type": "number",
          "description": "The timestamp of generation"
        },
        "spaceId": {
          "type": "string",
          "description": "The ID of the space this SVG is associated with"
        }
      },
      "required": ["uid", "prompt", "content", "timestamp"]
    },
    "Space": {
      "title": "Space",
      "description": "A reference point for generations",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user ID of the creator"
        },
        "title": {
          "type": "string",
          "description": "Title of the space"
        },
        "description": {
          "type": "string",
          "description": "Description of the space"
        },
        "prompt": {
          "type": "string",
          "description": "Guidance prompt for this space"
        },
        "knowledge": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["file", "url"] },
              "value": { "type": "string" },
              "name": { "type": "string" },
              "mimeType": { "type": "string" }
            }
          }
        },
        "timestamp": {
          "type": "number",
          "description": "Creation timestamp"
        }
      },
      "required": ["uid", "title", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/users/{userId}/svgs/{svgId}": {
      "schema": { "$ref": "SvgDocument" },
      "description": "Generated SVGs for a user"
    },
    "/users/{userId}/spaces/{spaceId}": {
      "schema": { "$ref": "Space" },
      "description": "User spaces"
    }
  }
}
