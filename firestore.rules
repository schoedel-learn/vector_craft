rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - role: string (required, 'admin' or 'user')
    //   - avatarConfig: map (optional)
    //     - style: string
    //     - seed: string
    //
    // Collection: users/{userId}/svgs
    // Document ID: {svgId}
    // Fields:
    //   - uid: string (required, must match userId)
    //   - prompt: string (required, max length 500)
    //   - content: string (required, max length 100000)
    //   - timestamp: number (required, positive)
    //
    // Collection: allowed_clients
    // Document ID: {email}
    // Fields:
    //   - addedBy: string
    //   - timestamp: number
    //
    // Collection: users/{userId}/spaces
    // Document ID: {spaceId}
    // Fields:
    //   - uid: string (required, must match userId)
    //   - title: string (required, max length 100)
    //   - description: string (optional, max length 500)
    //   - prompt: string (optional, max length 2000)
    //   - knowledge: list (optional, max size 10)
    //   - timestamp: number (required, positive)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] > 0;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "schoedelb@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['role', 'avatarConfig']) &&
             data.role in ['admin', 'user'] &&
             (!('avatarConfig' in data) || (
               data.avatarConfig is map &&
               data.avatarConfig.keys().hasOnly(['style', 'seed']) &&
               data.avatarConfig.style is string &&
               data.avatarConfig.seed is string &&
               data.avatarConfig.style.size() < 50 &&
               data.avatarConfig.seed.size() < 100
             ));
    }

    function isValidSvgDocument(data) {
      return hasOnlyAllowedFields(['uid', 'prompt', 'content', 'timestamp', 'spaceId']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             validStringLength('prompt', 1, 1000) &&
             validStringLength('content', 1, 200000) &&
             isPositive('timestamp') &&
             (!('spaceId' in data) || data.spaceId is string || data.spaceId == null);
    }

    function isValidSpace(data) {
      return hasOnlyAllowedFields(['uid', 'title', 'description', 'prompt', 'knowledge', 'timestamp']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             validStringLength('title', 1, 100) &&
             (!('description' in data) || validStringLength('description', 0, 500)) &&
             (!('prompt' in data) || validStringLength('prompt', 0, 2000)) &&
             (!('knowledge' in data) || data.knowledge is list) &&
             isPositive('timestamp');
    }

    function isValidAllowedClient(data) {
      return hasOnlyAllowedFields(['addedBy', 'timestamp']) &&
             data.addedBy is string &&
             isPositive('timestamp');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /allowed_clients/{email} {
      allow read: if isAuthenticated() && (request.auth.token.email == email || isAdmin());
      allow write: if isAdmin() && isValidAllowedClient(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();

      match /svgs/{svgId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && 
                         isValidSvgDocument(request.resource.data) && 
                         uidUnchanged() && 
                         request.resource.data.uid == userId;
        allow update: if isOwner(userId) && 
                         isValidSvgDocument(request.resource.data) && 
                         uidNotModified() && 
                         request.resource.data.uid == userId;
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /spaces/{spaceId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && 
                         isValidSpace(request.resource.data) && 
                         uidUnchanged() && 
                         request.resource.data.uid == userId;
        allow update: if isOwner(userId) && 
                         isValidSpace(request.resource.data) && 
                         uidNotModified() && 
                         request.resource.data.uid == userId;
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
